# ============================================
# SkillSwap Backend — Environment Variables
# Copy to .env and fill in values
# ============================================

# --- Server ---
NODE_ENV=development
PORT=4000
AUTH_DEBUG=true

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=30d

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Redis (Bull queues + Leaderboard cache) ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- OpenAI (Embeddings + GPT-4o) ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_EMBEDDING_DIMENSIONS=1536

# --- Google Gemini (Fallback AI) ---
GEMINI_API_KEY=your_gemini_api_key

# --- Agora (Video, RTM, Whiteboard) ---
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# --- Email (Nodemailer SMTP Gmail) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="SkillSwap <noreply@skillswap.app>"

# --- Frontend URL (CORS + email links) ---
FRONTEND_URL=http://localhost:5173
APP_NAME=SkillSwap

# --- Sentry (Error tracking) ---
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# --- Supabase Storage ---
STORAGE_BUCKET_AVATARS=avatars
STORAGE_BUCKET_FILES=session-files
STORAGE_BUCKET_RECORDINGS=recordings

# --- Misc ---
BCRYPT_COST_FACTOR=12
MFA_APP_NAME=SkillSwap
