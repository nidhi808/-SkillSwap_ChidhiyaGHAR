{
  "name": "skillswap-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for SkillSwap peer-to-peer skill exchange marketplace",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:workers": "nodemon src/workers/index.js",
    "workers": "node src/workers/index.js",
    "test": "jest --coverage --forceExit",
    "lint": "eslint src/",
    "db:migrate": "node scripts/migrate.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@langchain/community": "^0.3.0",
    "@sentry/node": "^8.38.0",
    "@supabase/supabase-js": "^2.46.0",
    "agora-access-token": "^2.0.4",
    "bcrypt": "^5.1.1",
    "bull": "^4.16.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.15",
    "openai": "^4.68.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.0",
    "speakeasy": "^2.0.0",
    "tls-sig-api-v2": "^1.0.2",
    "uuid": "^10.0.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  }
}
